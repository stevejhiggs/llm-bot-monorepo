# Calls Anthropic directly (no gateway). Required.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: a GitHub token with repo read access, for cloning PRIVATE repos.
# Also used by the GitHub channel to post comments back as that account.
# GITHUB_TOKEN="ghp_..."

# Required to receive GitHub webhooks: the secret configured on the webhook.
# Each delivery's signature is verified against this before the handler runs.
# GITHUB_WEBHOOK_SECRET="..."

# Optional: the comment phrase that activates the bot on issues/PRs.
# Defaults to "@d0lt-bot".
# GITHUB_TRIGGER_PHRASE="@d0lt-bot"

# Required to receive Slack events: the app's Signing Secret. Each request's
# signature is verified against this before the handler runs.
# SLACK_SIGNING_SECRET="..."

# Required for the Slack channel to post replies: the bot user OAuth token.
# SLACK_BOT_TOKEN="xoxb-..."

# Opt-in to the direct agent HTTP endpoint (POST /agents/d0lt-bot/:id). Unset (the
# default) means no public HTTP surface — the bot is reachable only via the verified
# GitHub/Slack channels. Set to any non-empty value to enable it. The endpoint is
# unauthenticated as shipped; add auth in the route middleware before enabling in prod.
ALLOW_HTTP_ACCESS="1"

# Sandbox selection. Unset/"local" uses the node local() shell sandbox (default).
# The Cloudflare build sets this to "cloudflare" (see package.json scripts).
FLUE_SANDBOX="local"
