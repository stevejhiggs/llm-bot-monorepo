# Calls Anthropic directly (no gateway). Required.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: a GitHub token with repo read access, for cloning PRIVATE repos.
# Also used by the GitHub channel to post comments back as that account.
# GITHUB_TOKEN="ghp_..."

# Required to receive GitHub webhooks: the secret configured on the webhook.
# Each delivery's signature is verified against this before the handler runs.
# GITHUB_WEBHOOK_SECRET="..."

# Optional: the comment phrase that activates the bot on issues/PRs.
# Defaults to "@d0lt-bot".
# GITHUB_TRIGGER_PHRASE="@d0lt-bot"

# Sandbox selection. Unset/"local" uses the node local() shell sandbox (default).
# The Cloudflare build sets this to "cloudflare" (see package.json scripts).
# FLUE_SANDBOX="local"
