{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "d0lt-bot",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // Non-secret channel enable flags. Channels are opt-in via CHANNEL_<NAME>_ENABLE
  // (read through channelEnabled() / process.env). Unlike the per-channel secrets
  // (SLACK_SIGNING_SECRET, etc., set via `wrangler secret put`), these are plain
  // booleans, so they belong here as vars — otherwise a deployed Worker has them
  // unset and the channel stays inert (placeholder signing secret → Slack
  // deliveries 401, handler ignores everything) even when its secrets are set.
  "vars": {
    "CHANNEL_SLACK_ENABLE": "1",
  },
  "durable_objects": {
    "bindings": [{ "class_name": "Sandbox", "name": "Sandbox" }],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FlueRegistry", "FlueD0ltBotAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["Sandbox"] },
  ],
  "containers": [{ "class_name": "Sandbox", "image": "./Dockerfile" }],
  // Cloudflare-native observability: persists console logs and worker/DO
  // invocation traces to the Cloudflare dashboard (Workers > d0lt-bot >
  // Observability). `enabled` is the master switch — it must be true for the
  // `logs`/`traces` sub-blocks below to take effect. This is independent of any
  // OpenTelemetry pipeline; CF does not ingest external OTLP spans here.
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
