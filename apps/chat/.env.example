# Base URL of the d0lt-bot Flue runner. Read server-side only: this app's
# server proxies browser requests under /api/flue to the runner (see
# src/server.ts), so the runner URL is never exposed to the browser and no
# CORS is required. The runner must have CHANNEL_HTTP_ENABLE=true.
FLUE_RUNNER_URL=http://localhost:3583
