{
  "name": "d0lt-bot",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "connect": "flue connect d0lt-bot local",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:cf": "FLUE_SANDBOX=cloudflare flue dev --target cloudflare",
    "build:cf": "FLUE_SANDBOX=cloudflare flue build --target cloudflare",
    "deploy": "FLUE_SANDBOX=cloudflare flue build --target cloudflare && wrangler deploy --config dist/d0lt_bot/wrangler.json"
  },
  "dependencies": {
    "@cloudflare/sandbox": "catalog:cf",
    "@flue/github": "catalog:flue",
    "@flue/runtime": "catalog:flue",
    "@flue/slack": "catalog:flue",
    "@repo/channel-registry": "workspace:*",
    "@repo/github": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/sandbox": "workspace:*",
    "@repo/slack": "workspace:*",
    "agents": "^0.16.2",
    "hono": "^4.12.22"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.1",
    "@types/node": "catalog:tooling",
    "typescript": "catalog:tooling",
    "vitest": "catalog:testing",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": "24.x"
  }
}
