{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "d0lt-bot",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // Non-secret runtime vars. These are read from process.env at runtime, so the
  // build-time env (the FLUE_SANDBOX=cloudflare the deploy script sets, the
  // CHANNEL_* flags in .dev.vars) does NOT reach the deployed Worker — they must be
  // declared here or the Worker runs with them unset.
  //
  //  - FLUE_SANDBOX selects the sandbox at runtime (resolveSandboxKind). Without it
  //    a deployed Worker falls back to the node local() sandbox, whose shell calls
  //    child_process.spawnSync — unimplemented on workerd, so every clone/test fails.
  //  - CHANNEL_<NAME>_ENABLE opt channels in (channelEnabled()); unset → the channel
  //    boots inert with a placeholder secret and 401s every delivery.
  // (Per-channel secrets like SLACK_SIGNING_SECRET are NOT vars — set them via
  // `wrangler secret put`.)
  "vars": {
    "FLUE_SANDBOX": "cloudflare",
    "CHANNEL_SLACK_ENABLE": "1",
  },
  "durable_objects": {
    "bindings": [{ "class_name": "Sandbox", "name": "Sandbox" }],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FlueRegistry", "FlueD0ltBotAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["Sandbox"] },
  ],
  // The sandbox clones repos and runs installs/tests. The default (dev/lite) is
  // 1/16 vCPU + 256 MiB — too small (OOMs on npm install). basic = 1/4 vCPU /
  // 1 GiB / 4 GB disk; bump to a standard-* tier if larger repos OOM.
  "containers": [{ "class_name": "Sandbox", "image": "./Dockerfile", "instance_type": "basic" }],
  // Cloudflare-native observability: persists console logs and worker/DO
  // invocation traces to the Cloudflare dashboard (Workers > d0lt-bot >
  // Observability). `enabled` is the master switch — it must be true for the
  // `logs`/`traces` sub-blocks below to take effect. This is independent of any
  // OpenTelemetry pipeline; CF does not ingest external OTLP spans here.
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
