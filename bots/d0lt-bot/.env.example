# Calls Anthropic directly (no gateway). Required.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: a GitHub token. Clones PRIVATE repos in the sandbox, and (when the GitHub
# channel is enabled) posts comments back as that account.
# GITHUB_TOKEN="ghp_..."

# --- Channels are opt-in -------------------------------------------------------------
# Each channel (and the direct HTTP route) is enabled only when its CHANNEL_<NAME>_ENABLE
# var is set to a non-empty value. A disabled channel needs no secret to boot; enabling
# one requires the secrets listed beneath it.

# GitHub channel: reacts to PR/issue comments and posts results back.
# CHANNEL_GITHUB_ENABLE="1"
# GITHUB_WEBHOOK_SECRET="..."        # required when enabled: verifies inbound webhooks
# GITHUB_TRIGGER_PHRASE="@d0lt-bot"  # optional: phrase that activates the bot (default "@d0lt-bot")

# Slack channel: reacts to @-mentions and DMs, replies in-thread.
# CHANNEL_SLACK_ENABLE="1"
# SLACK_SIGNING_SECRET="..."         # required when enabled: verifies inbound events
# SLACK_BOT_TOKEN="xoxb-..."         # required when enabled: the bot user OAuth token

# Direct agent HTTP endpoint (POST /agents/d0lt-bot/:id). Off → the endpoint 404s. The
# handler is an unauthenticated pass-through; add auth in the route middleware before
# enabling in prod.
CHANNEL_HTTP_ENABLE="1"

# Sandbox selection. Unset/"local" uses the node local() shell sandbox (default).
# The Cloudflare build sets this to "cloudflare" (see package.json scripts).
FLUE_SANDBOX="local"
