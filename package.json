{
  "name": "d0lt-bot-flue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "console": "pnpm --filter d0lt-bot console",
    "test": "turbo run test",
    "lint": "oxlint --fix && oxfmt",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "catalog:tooling",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.18",
    "typescript": "7.0.1-rc"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.8.0"
}
