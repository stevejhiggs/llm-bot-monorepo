{
  "name": "d0lt-bot-flue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "connect": "pnpm --filter d0lt-bot connect",
    "test": "pnpm --filter d0lt-bot test",
