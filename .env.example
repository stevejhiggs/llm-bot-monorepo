# Calls Anthropic directly (no gateway). Required.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: a GitHub token with repo read access, for cloning PRIVATE repos.
# GITHUB_TOKEN="ghp_..."

# Base URL the chat agent's tools use to reach this app's own workflow routes.
# Defaults to the dev server (http://127.0.0.1:3583). Override if you change the port.
# FLUE_SELF_URL="http://127.0.0.1:3583"
